# Trinity HSLM Training — ARM64 Native (macOS to Linux ARM64)
# Copies prebuilt binaries from host instead of building in Docker
#
# φ² + 1/φ² = 3 = TRINITY

FROM ubuntu:24.04

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates wget libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

# Setup data directories
RUN mkdir -p /data/tinystories /data/checkpoints

# Download TinyStories dataset
RUN wget -q "https://huggingface.co/datasets/roneneldan/TinyStories/resolve/main/TinyStoriesV2-GPT4-train.txt" \
    -O /data/tinystories/train_100k.txt && \
    echo "Dataset downloaded: $(wc -l < /data/tinystories/train_100k.txt) lines"

# Copy prebuilt ARM64 Linux binaries from host
# Built with: zig build-exe -target aarch64-linux-gnu -O ReleaseFast -lc -femit-bin=zig-out-linux/hslm-entrypoint src/cli/entrypoint_train.zig
COPY zig-out-linux/hslm-entrypoint /usr/local/bin/hslm-entrypoint
COPY zig-out-linux/hslm-train /usr/local/bin/hslm-train

WORKDIR /data

ENTRYPOINT ["/usr/local/bin/hslm-entrypoint"]

LABEL version="2.4.0-arm64-local" \
      description="Trinity HSLM Training — ARM64 native binaries from host" \
      trinity.identity="phi^2 + 1/phi^2 = 3" \
      trinity.service="ai-training" \
      trinity.purpose="nlp-research"
