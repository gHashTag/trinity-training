[spec]
name = "hslm_attention"
version = "1.0.0"
description = "VSA-based sacred attention with ternary cosine similarity"

[interface]
inputs = ["query: [81]Trit", "key: [81]Trit", "value: [81]Trit"]
outputs = ["attended: [81]Trit"]

[invariants]
dim = "81 (3^4)"
no_softmax = "cosine similarity scoring only"
ternary = "all weights in {-1, 0, +1}"

[architecture]
scoring = "cosine similarity between Q and K"
aggregation = "weighted bundle of V vectors"
heads = "3 (trinity number)"
