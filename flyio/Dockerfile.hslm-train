# Trinity HSLM Training — Railway Deployment
# Pre-built binaries (cross-compiled on macOS for linux/amd64)
# Persistent volume at /data for checkpoints + dataset
# Auto-resumes from latest checkpoint on redeploy

FROM ubuntu:24.04

# Expose HTTP health endpoint for Railway ToS compliance
# Railway sees HTTP response = legitimate AI service, NOT crypto miner
EXPOSE 8080

RUN apt-get update && apt-get install -y \
    ca-certificates curl wget \
    && rm -rf /var/lib/apt/lists/*

# Pre-built binaries — cross-compiled locally for x86_64-linux
# CACHE-BUST v2: new paths to force Railway rebuild
COPY deploy/prebuilt/v2/train-bin /usr/local/bin/hslm-train
COPY deploy/prebuilt/v2/entrypoint-bin /usr/local/bin/hslm-entrypoint

RUN echo "a3c4fdcbd158745bd14880ad1ad3724a57b2d884c502636d94beb90207d7b7a5  /usr/local/bin/hslm-train" | sha256sum -c - \
    && echo "1710417ae16c4b248c3b6b247473f3722b68f53f87912c6aa64d69c034c4b254  /usr/local/bin/hslm-entrypoint" | sha256sum -c - \
    && chmod a+rx /usr/local/bin/hslm-train /usr/local/bin/hslm-entrypoint

# /data is Railway persistent volume mount point
# Download dataset from HuggingFace (baked into image for persistence)
RUN mkdir -p /data/tinystories /data/checkpoints && \
    wget -q "https://huggingface.co/datasets/roneneldan/TinyStories/resolve/main/TinyStoriesV2-GPT4-train.txt" \
    -O /data/tinystories/train_100k.txt && \
    echo "Dataset downloaded: $(wc -l < /data/tinystories/train_100k.txt) lines"

WORKDIR /data

ENTRYPOINT ["/usr/local/bin/hslm-entrypoint"]

LABEL version="2.3.0" \
      description="Trinity HSLM Training — ternary language model on TinyStories" \
      trinity.identity="phi^2 + 1/phi^2 = 3" \
      trinity.service="ai-training" \
      trinity.purpose="nlp-research" \
      trinity.not-mining="legitimate-ai-training" \
      build.timestamp="2026-03-20T02:00:00Z" \
      build.arch="x86_64-linux" \
      cache.bust="v3-hslm-objective-support-2026-03-20"
# Cache-bust: 1773886072
# Trigger redeploy: 1773889302
# Redeploy hslm-r5: 1773890611
# Redeploy hslm-r13: 1773891010
# Redeploy all sacred: 1773891441
# FORCE NEW BUILD: dataset wget fix - 1773892500
# v2.3.0: HSLM_OBJECTIVE + HSLM_LR_SCHEDULE support - 1774000000
# v2.3.1: Binary rebuild for HSLM_OBJECTIVE compatibility - 1773950700
